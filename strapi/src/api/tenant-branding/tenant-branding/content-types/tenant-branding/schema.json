    "tenantKey": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "brandName": {
      "type": "string",
      "required": true
    },
    "brandIcon": {
      "type": "string",
      "default": ""
    },
    "logoUrl": {
      "type": "string"
    },
    "theme": {
      "type": "json",
      "required": true
    },
    "navCategories": {
      "type": "json",
      "required": true
    },
    "footerLinks": {
      "type": "json"
    },
    "promoText": {
      "type": "string"
    }
  }
}
