{
  "kind": "collectionType",
  "collectionName": "tenant_brandings",
  "info": {
    "singularName": "tenant-branding",
    "pluralName": "tenant-brandings",
    "displayName": "Tenant Branding",
    "description": "Per-tenant storefront configuration: colors, navigation categories, footer links, and brand identity."
