{
  "name": "juli",
  "version": "0.1.0",
  "private": true,
  "description": "Official Spartacus storefront for Ubris + Strapi",
  "scripts": {
    "ng": "node ./scripts/run-angular-cli.js",
    "start": "node ./scripts/run-angular-cli.js serve --proxy-config proxy.conf.json --disable-host-check --host 0.0.0.0",
    "serve:prod": "node server.js",
    "build": "node ./scripts/run-angular-cli.js build --configuration development",
    "build:prod": "node ./scripts/run-angular-cli.js build --configuration production",
    "build:strict-crypto": "node ./scripts/run-angular-cli.js --without-legacy-provider build --configuration production",
    "watch": "node ./scripts/run-angular-cli.js build --watch --configuration development",
    "test": "node ./scripts/run-angular-cli.js test",
    "test:ci": "CI=true node ./scripts/run-angular-cli.js test --watch=false --code-coverage",
    "test:occ-smoke": "node ./scripts/run-angular-cli.js test --watch=false --browsers=ChromeHeadless --include=src/app/core/commerce/adapters/hybris/__tests__/occ-compatibility.smoke.spec.ts",
    "validate:types": "npm run build",
    "e2e": "npx playwright test",
    "e2e:standalone": "JULI_E2E_SERVER_MODE=standalone npx playwright test",
    "e2e:proxy": "JULI_E2E_SERVER_MODE=proxy npx playwright test",
    "e2e:headed": "npx playwright test --headed",
    "e2e:report": "npx playwright show-report"
  },
  "dependencies": {
    "@angular/animations": "~12.2.0",
    "@angular/common": "~12.2.0",
    "@angular/compiler": "~12.2.0",
    "@angular/core": "~12.2.0",
    "@angular/forms": "~12.2.0",
    "@angular/platform-browser": "~12.2.0",
    "@angular/platform-browser-dynamic": "~12.2.0",
    "@angular/router": "~12.2.0",
    "@angular/service-worker": "~12.2.0",
    "@ng-bootstrap/ng-bootstrap": "^10.0.0",
    "@ng-select/ng-select": "^7.0.1",
    "@ngrx/effects": "^12.1.0",
    "@ngrx/router-store": "^12.1.0",
    "@ngrx/store": "^12.1.0",
    "@spartacus/cart": "^4.3.8",
    "@spartacus/checkout": "^4.3.8",
    "@spartacus/core": "4.3.8",
    "@spartacus/storefront": "4.3.8",
    "@stripe/stripe-js": "^4.8.0",
    "angular-oauth2-oidc": "^10.0.1",
    "i18next": "^20.2.2",
    "i18next-http-backend": "^1.2.2",
    "ngx-infinite-scroll": "^8.0.0",
    "rxjs": "~6.6.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.11.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~12.2.18",
    "@angular/cli": "~12.2.18",
    "@angular/compiler-cli": "~12.2.0",
    "@playwright/test": "^1.59.1",
    "@types/jasmine": "~3.8.0",
    "@types/node": "^12.11.1",
    "jasmine-core": "~3.8.0",
    "karma": "~6.3.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.0.3",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "~1.7.0",
    "typescript": "~4.3.5"
  }
}
